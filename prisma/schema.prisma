generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum MediaType {
  image
  video
}

enum SocialPlatform {
  x
  instagram
  threads
  tiktok
  whatsapp
}

model AdminUser {
  id                  String    @id @default(cuid())
  username            String    @unique
  fullName            String    @map("full_name")
  email               String    @unique
  avatarUrl           String?   @map("avatar_url")
  passwordHash        String
  role                String    @default("admin")
  isActive            Boolean   @default(true)  @map("is_active")
  isVerified          Boolean   @default(false) @map("is_verified")
  verifiedAt          DateTime?                 @map("verified_at")
  verificationToken   String?                   @map("verification_token")
  resetToken          String?                   @map("reset_token")
  resetTokenExpiresAt DateTime?                 @map("reset_token_expires_at")
  lastLoginAt         DateTime?                 @map("last_login_at")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("admin_users")
}

model Booking {
  id              String        @id @default(cuid())
  date            DateTime
  timeLabel       String
  name            String
  email           String
  phone           String?
  service         String
  status          BookingStatus @default(pending)
  notes           String?
  reviewCode      String?
  reviewSubmitted Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([date])
  @@index([status])
  @@map("bookings")
}

model Review {
  id        String        @id @default(cuid())
  author    String
  role      String?
  quote     String
  isActive  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  media     ReviewMedia[]

  @@map("reviews")
}

model ReviewMedia {
  id        String    @id @default(cuid())
  reviewId  String
  src       String
  type      MediaType
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_media")
}

model VaultCollection {
  id         String      @id @default(cuid())
  title      String
  category   String
  thumb      String
  code       String
  isVideo    Boolean     @default(false)
  columnSpan Int         @default(1)
  rowSpan    Int         @default(1)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  media      VaultMedia[]

  @@index([sortOrder])
  @@map("vault_collections")
}



model VaultMedia {
  id           String    @id @default(cuid())
  collectionId String
  src          String
  type         MediaType
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  collection VaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
  @@map("vault_media")
}

model SocialLink {
  id        String         @id @default(cuid())
  platform  SocialPlatform @unique
  url       String
  isVisible Boolean        @default(true) @map("is_visible")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("social_links")
}

model TiktokIntegration {
  id               String   @id @default(cuid())
  username         String   @unique
  displayName      String?  @map("display_name")
  avatarUrl        String?  @map("avatar_url")
  followerCount    Int      @default(0) @map("follower_count")
  likeCount        Int      @default(0) @map("like_count")
  videoCount       Int      @default(0) @map("video_count")
  accessToken      String   @map("access_token")
  refreshToken     String   @map("refresh_token")
  tokenExpiresAt   DateTime @map("token_expires_at")
  refreshExpiresAt DateTime @map("refresh_expires_at")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("tiktok_integrations")
}


model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

enum PublicSection {
  about
  expertise
  hero
}

model PublicCollection {
  id        String        @id @default(cuid())
  title     String?
  src       String
  type      MediaType     @default(video)
  section   PublicSection
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([section, sortOrder])
  @@map("public_collections")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([isRead])
  @@map("contact_messages")
}

model PageVisit {
  id         String   @id @default(cuid())
  path       String
  sessionId  String?  @map("session_id")
  referrer   String?
  userAgent  String   @map("user_agent")
  browser    String
  os         String
  deviceType String   @map("device_type")
  language   String?
  country    String?
  ipHash     String?  @map("ip_hash")
  visitedAt  DateTime @default(now()) @map("visited_at")

  @@index([visitedAt])
  @@index([browser])
  @@index([path])
  @@index([deviceType])
  @@index([sessionId, visitedAt])
  @@index([path, visitedAt])
  @@map("page_visits")
}