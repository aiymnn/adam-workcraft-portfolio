# PostgreSQL + Prisma
# Set these yourself based on your local PostgreSQL user/database.
# For Docker Compose production, use DB_HOST=db and keep DB_PORT=5432.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=adam-workcraft
DB_USER=dbuser
DB_PASSWORD=dbpassword

# Prisma main connection
DATABASE_URL=postgresql://dbuser:dbpassword@127.0.0.1:5432/adam-workcraft?schema=public

# Optional direct URL for admin tools / heavy migrations
DIRECT_URL=postgresql://dbuser:dbpassword@127.0.0.1:5432/adam-workcraft?schema=public

# Optional: set if your DB user cannot create databases automatically for shadow DB
SHADOW_DATABASE_URL=postgresql://dbuser:dbpassword@127.0.0.1:5432/adam-workcraft_shadow?schema=public

# pgAdmin (only if you use docker compose + pgAdmin)
PGADMIN_PASSWORD=your_pgadmin_password

# Auth.js
AUTH_SECRET=generate_via_npx_auth_secret
AUTH_URL=http://localhost:3000

# Initial admin bootstrap (used once on first successful login when admin_users is empty)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
ADMIN_EMAIL=

# Google Drive Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_DRIVE_AUTH_MODE=auto

# OAuth mode (use this for personal/free My Drive)
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# Service-account mode (recommended for Shared Drive / production workspace)
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON_BASE64=
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=./google-service-account.json
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_PROJECT_ID=image-gallery-497516
GOOGLE_DRIVE_MAX_UPLOAD_MB=20
GOOGLE_DRIVE_PUBLIC_BY_DEFAULT=false
GOOGLE_DRIVE_REQUIRE_ADMIN_FOR_FETCH=false

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
CONTACT_EMAIL=hello@adamworkcraft.com

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server runtime
NODE_ENV=production
